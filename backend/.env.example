# Server
PORT=3000
API_PUBLIC_URL=https://api.callai.com
VOICE_GATEWAY_WS_URL=wss://your-ngrok-domain.ngrok-free.dev/v1/voice-stream
NODE_ENV=development

# Security
VOICE_GATEWAY_TOKEN=bypass-auth
JWT_SECRET=super-secret-jwt-key-change-in-production-min-16-chars
JWT_EXPIRATION=24h

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/callai?schema=public

# Redis & Queues
REDIS_HOST=localhost
REDIS_PORT=6379

# Telephony (Exotel)
EXOTEL_API_KEY=your-exotel-key
EXOTEL_API_TOKEN=your-exotel-token
EXOTEL_ACCOUNT_SID=your-exotel-account-sid
EXOTEL_SUBDOMAIN=api.exotel.com
EXOTEL_CALLER_ID=your-exotel-virtual-number

# Telephony (Twilio)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_NUMBER=your-twilio-virtual-number
TWILIO_SUBDOMAIN=api.twilio.com

# AI Providers
OPENAI_API_KEY=your-openai-api-key
GEMINI_API_KEY=your-gemini-api-key

# AWS (S3 Storage)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_S3_RECORDINGS_BUCKET=call-ai-recordings

# ─── Latency-Aware Intelligence Layer ─────────────────────────────────────────
# Master kill switch — set to false to disable entirely (default: off)
ENABLE_LATENCY_LAYER=false

# Strategy thresholds (milliseconds)
# avg < FULL_MS        → FULL   (normal unconstrained response)
# avg < SHORT_MS       → SHORT  (one-sentence constraint appended to prompt)
# avg >= SHORT_MS      → FILLER (bridging phrase sent immediately)
LATENCY_THRESHOLD_FULL_MS=400
LATENCY_THRESHOLD_SHORT_MS=800

# Spike detection: escalates one tier when lastLatency > multiplier × avg
# Only triggers when avg exceeds SPIKE_MIN_AVG_MS (avoids false positives at call start)
LATENCY_SPIKE_MULTIPLIER=2.0
LATENCY_SPIKE_MIN_AVG_MS=200

# Minimum gap between FILLER emissions per session (prevents audio spam)
LATENCY_FILLER_COOLDOWN_MS=3000
