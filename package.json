{
  "name": "call-ai-monorepo",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter call-ai start:dev & pnpm --filter frontend dev",
    "start:backend": "pnpm --filter call-ai start:dev",
    "start:frontend": "pnpm --filter frontend dev",
    "prisma:generate": "pnpm --filter call-ai prisma:generate",
    "prisma:migrate": "pnpm --filter call-ai prisma:migrate",
    "db:seed": "pnpm --filter call-ai exec prisma db seed",
    "test:backend": "pnpm --filter call-ai test"
  },
  "dependencies": {},
  "devDependencies": {}
}
